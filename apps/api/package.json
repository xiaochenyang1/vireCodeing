{
  "name": "@truck-platform/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "test": "jest --config jest.config.js --runInBand",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:validate": "cross-env DATABASE_URL=postgresql://truck:truck@localhost:5432/truck_platform prisma validate",
    "prisma:generate": "cross-env DATABASE_URL=postgresql://truck:truck@localhost:5432/truck_platform prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.10.2",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.3"
  }
}
