{
  "name": "@truck-platform/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "test": "jest --config jest.config.js --runInBand",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:validate": "cross-env DATABASE_URL=postgresql://truck:truck@localhost:5432/truck_platform prisma validate",
    "prisma:generate": "cross-env DATABASE_URL=postgresql://truck:truck@localhost:5432/truck_platform prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "db:dev:postgres:up": "docker compose -f docker-compose.postgres.yml up -d postgres",
    "db:dev:postgres:down": "docker compose -f docker-compose.postgres.yml down",
    "db:dev:minio:up": "docker compose -f docker-compose.minio.yml up -d",
    "db:dev:minio:down": "docker compose -f docker-compose.minio.yml down",
    "db:postgres:doctor": "node scripts/verify-postgres.js doctor",
    "db:postgres:wait": "node scripts/verify-postgres.js wait",
    "db:postgres:status": "node scripts/verify-postgres.js status",
    "db:postgres:deploy": "node scripts/verify-postgres.js deploy",
    "db:postgres:bootstrap": "npm run db:postgres:wait && npm run db:postgres:deploy && npm run prisma:generate && npm run db:postgres:order-coupon-migration-verify && npm run db:postgres:seed && npm run db:postgres:auth-smoke && npm run db:postgres:order-smoke && npm run db:postgres:driver-certification-smoke && npm run db:postgres:order-mutation-concurrency-smoke && npm run db:postgres:order-coupon-atomicity-smoke && npm run db:postgres:financial-ledger-smoke",
    "db:test:postgres:doctor": "node scripts/verify-postgres.js doctor --test",
    "db:test:postgres:wait": "node scripts/verify-postgres.js wait --test",
    "db:test:postgres:status": "node scripts/verify-postgres.js status --test",
    "db:test:postgres:deploy": "node scripts/verify-postgres.js deploy --test",
    "db:test:postgres:bootstrap": "npm run db:test:postgres:wait && npm run db:test:postgres:deploy && npm run prisma:generate && npm run db:test:postgres:order-coupon-migration-verify && npm run db:test:postgres:seed && npm run db:test:postgres:auth-smoke && npm run db:test:postgres:order-smoke && npm run db:test:postgres:driver-certification-smoke && npm run db:test:postgres:order-mutation-concurrency-smoke && npm run db:test:postgres:order-coupon-atomicity-smoke && npm run db:test:postgres:financial-ledger-smoke",
    "db:postgres:order-coupon-migration-verify": "node scripts/verify-order-coupon-migration.js",
    "db:test:postgres:order-coupon-migration-verify": "node scripts/verify-order-coupon-migration.js --test",
    "db:postgres:seed": "node scripts/seed-stage-1.js seed",
    "db:test:postgres:seed": "node scripts/seed-stage-1.js seed --test",
    "db:postgres:auth-smoke": "node scripts/seed-stage-1.js auth-smoke",
    "db:test:postgres:auth-smoke": "node scripts/seed-stage-1.js auth-smoke --test",
    "db:postgres:order-smoke": "node scripts/seed-stage-1.js order-smoke",
    "db:test:postgres:order-smoke": "node scripts/seed-stage-1.js order-smoke --test",
    "db:postgres:driver-certification-smoke": "node scripts/seed-stage-1.js driver-certification-smoke",
    "db:test:postgres:driver-certification-smoke": "node scripts/seed-stage-1.js driver-certification-smoke --test",
    "db:postgres:order-mutation-concurrency-smoke": "node scripts/seed-stage-1.js order-mutation-concurrency-smoke",
    "db:test:postgres:order-mutation-concurrency-smoke": "node scripts/seed-stage-1.js order-mutation-concurrency-smoke --test",
    "db:postgres:order-coupon-atomicity-smoke": "node scripts/seed-stage-1.js order-coupon-atomicity-smoke",
    "db:test:postgres:order-coupon-atomicity-smoke": "node scripts/seed-stage-1.js order-coupon-atomicity-smoke --test",
    "db:postgres:financial-ledger-smoke": "node scripts/verify-financial-ledger.js",
    "db:test:postgres:financial-ledger-smoke": "node scripts/verify-financial-ledger.js --test",
    "db:postgres:sms-smoke": "node scripts/verify-sms-webhook.js",
    "db:test:postgres:sms-smoke": "node scripts/verify-sms-webhook.js --test",
    "db:postgres:s3-smoke": "node scripts/verify-s3-file-storage.js",
    "db:test:postgres:s3-smoke": "node scripts/verify-s3-file-storage.js --test"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.10.2",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.3"
  }
}
