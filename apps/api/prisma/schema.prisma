generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  shipper
  driver
  admin
}

enum UserStatus {
  active
  disabled
}

enum VerificationPurpose {
  login
  register
  reset
}

enum FilePurpose {
  avatar
  identity
  cargo
  exception
  evaluation
  receipt
  invoice
}

enum FileStatus {
  pending
  uploaded
  rejected
}

enum CertificationStatus {
  unsubmitted
  reviewing
  approved
  rejected
}

enum DriverCertificationType {
  identity
  vehicle
}

enum OrderExceptionCaseSourceRole {
  shipper
  driver
}

enum OrderExceptionCaseStatus {
  pending
  processing
  resolved
  closed
}

enum OrderExceptionCaseCompensationStatus {
  not_required
  pending
  offline_completed
  executed
}

enum OrderExceptionCaseAppealStatus {
  none
  requested
  rejected
  accepted
}

enum OrderLocationGeocodeStatus {
  none
  sandbox
  manual
  amap
  failed
}

enum DriverLocationSource {
  manual
  device
  sandbox
}

enum InboxMessageCategory {
  order
  system
  service
  finance
}

enum InboxMessageAudience {
  shipper
  driver
  admin
}

enum PushDeliveryStatus {
  succeeded
  skipped
  failed
}

enum SupportTicketStatus {
  pending
  processing
  resolved
}

model User {
  id                          String                       @id @default(uuid())
  phone                       String                       @unique
  userType                    UserType
  status                      UserStatus                   @default(active)
  passwordHash                String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  sessions                    AuthSession[]
  files                       FileObject[]
  shipperProfile              ShipperProfile?
  orders                      Order[]                      @relation("ShipperOrders")
  orderDraft                  OrderDraft?
  addressBook                 ShipperAddressBook?
  frequentRoutes              ShipperFrequentRoutes?
  shipperCoupons              ShipperCoupon[]
  shipperIdentityVerification ShipperIdentityVerification?
  shipperEnterpriseVerification ShipperEnterpriseVerification?
  shipperInvoiceApplications  ShipperInvoiceApplication[]
  driverIdentityCertification DriverIdentityCertification? @relation("DriverIdentityCertification")
  driverVehicleCertification  DriverVehicleCertification?  @relation("DriverVehicleCertification")
  driverAcceptanceSettings    DriverAcceptanceSettings?
  driverWithdrawals           DriverWithdrawal[]            @relation("DriverWithdrawals")
  processedDriverWithdrawals  DriverWithdrawal[]            @relation("DriverWithdrawalProcessor")
  driverBankCards             DriverBankCard[]              @relation("DriverBankCards")
  assignedDriverOrders        Order[]                       @relation("AssignedDriverOrders")
  paymentOrders               PaymentOrder[]
  refunds                     Refund[]
  driverSettlements           Settlement[]
  driverWallet                DriverWallet?
  financialLedgerEntries      FinancialLedgerEntry[]
  financialAuditLogs          FinancialAuditLog[]
  adminAuthSessionGovernanceAuditEvents AdminAuthSessionGovernanceAuditEvent[] @relation("AdminAuthSessionGovernanceAuditActorEvents")
  driverCertificationReviewEvents DriverCertificationReviewEvent[] @relation("DriverCertificationReviewEvents")
  driverCertificationReviewerEvents DriverCertificationReviewEvent[] @relation("DriverCertificationReviewerEvents")
  orderIdempotencyRecords     OrderIdempotencyRecord[]   @relation("OrderIdempotencyActor")
  reportedExceptionCases       OrderExceptionCase[]       @relation("ExceptionCaseReporter")
  exceptionCaseActions         OrderExceptionCaseAction[] @relation("ExceptionCaseAdminActions")
  driverLocationSnapshot       DriverLocationSnapshot?    @relation("DriverLocationSnapshot")
  inboxMessages                InboxMessage[]             @relation("InboxMessageRecipient")
  shipperSupportTickets        ShipperSupportTicket[]
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String
  deviceId         String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id])

  @@index([refreshTokenHash, deviceId, revokedAt, expiresAt], name: "AuthSession_refresh_lookup_idx")
  @@index([userId, deviceId, revokedAt], name: "AuthSession_user_device_active_idx")
  @@index([userId, revokedAt], name: "AuthSession_user_active_idx")
}

model VerificationCode {
  id         String              @id @default(uuid())
  phone      String
  purpose    VerificationPurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime            @default(now())

  @@index([phone, purpose, consumedAt, expiresAt, createdAt], name: "VerificationCode_active_lookup_idx")
  @@index([phone, purpose, createdAt], name: "VerificationCode_rate_lookup_idx")
}

model FileObject {
  id          String     @id @default(uuid())
  ownerUserId String
  purpose     FilePurpose
  contentType String
  byteSize    Int
  objectKey   String
  publicUrl   String?
  etag        String?
  versionId   String?
  status      FileStatus @default(pending)
  createdAt   DateTime   @default(now())
  owner        User       @relation(fields: [ownerUserId], references: [id])
  shipperProfileAvatar ShipperProfile? @relation("ShipperProfileAvatar")
}

model ShipperProfile {
  userId                       String @id
  displayName                  String
  avatarFileId                 String? @unique
  phoneProtectionEnabled       Boolean @default(true)
  loginProtectionEnabled       Boolean @default(true)
  orderNotificationEnabled     Boolean @default(true)
  promotionNotificationEnabled Boolean @default(false)
  privacyConfirmedAt           DateTime?
  privacyPolicyVersion         String?
  privacyPolicyVersionTitle    String?
  identityStatus               String @default("unverified")
  enterpriseStatus             String @default("unverified")
  user                         User   @relation(fields: [userId], references: [id])
  avatarFile                   FileObject? @relation("ShipperProfileAvatar", fields: [avatarFileId], references: [id], onDelete: SetNull)
}

enum OrderStatus {
  waiting
  loading
  transporting
  confirming
  completed
  cancelled
}

enum PricingMode {
  fixed
  negotiable
}

enum PaymentMethod {
  cod
  online
}

enum OrderPaymentStatus {
  not_required
  pending
  escrowed
  settled
  failed
  cancelled
  refund_pending
  refunded
  refund_failed
  legacy_unverified
}

enum PaymentChannel {
  sandbox
  wechat
  alipay
}

enum PaymentOrderStatus {
  pending
  processing
  escrowed
  settled
  failed
  expired
  cancelled
  refund_pending
  refunded
  refund_failed
}

enum RefundStatus {
  pending
  processing
  succeeded
  failed
}

enum FinancialTransactionType {
  online_payment_escrow
  online_order_settlement
  offline_order_settlement
  online_refund
  driver_withdrawal
  order_compensation
}

enum FinancialAccountType {
  gateway_clearing
  platform_escrow
  driver_payable
  platform_revenue
  offline_clearing
}

enum LedgerDirection {
  debit
  credit
}

enum FinancialOutboxStatus {
  pending
  processing
  completed
  dead
}

enum AdminAuthSessionGovernanceAuditAction {
  revoke_session
  revoke_other_sessions
  revoke_account_sessions
}

enum AdminAuthSessionGovernanceAuditResult {
  revoked
  noop
}

model Order {
  id                   String             @id @default(uuid())
  orderNo              String             @unique
  shipperId            String
  status               OrderStatus        @default(waiting)
  pricingMode          PricingMode
  priceCents           Int?
  payablePriceCents    Int?
  paymentMethod        PaymentMethod
  paymentStatus        OrderPaymentStatus @default(legacy_unverified)
  assignedDriverId     String?
  paymentSettledAt     DateTime?
  refundedAt           DateTime?
  couponId             String?
  couponTitle          String?
  couponDiscountCents  Int?
  pickupTime           DateTime
  expectedDeliveryText String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  shipper              User               @relation("ShipperOrders", fields: [shipperId], references: [id])
  assignedDriver       User?              @relation("AssignedDriverOrders", fields: [assignedDriverId], references: [id])
  cargo                OrderCargo?
  locations            OrderLocation[]
  requirement          OrderRequirement?
  events               OrderEvent[]
  idempotencyRecords   OrderIdempotencyRecord[]
  exceptionCases       OrderExceptionCase[]
  paymentOrders        PaymentOrder[]
  refunds              Refund[]
  settlement           Settlement?
  financialTransactions FinancialTransaction[]
  driverLocationSnapshots DriverLocationSnapshot[]

  @@index([shipperId, status, createdAt], name: "Order_shipper_status_created_idx")
  @@index([shipperId, createdAt], name: "Order_shipper_created_idx")
  @@index([assignedDriverId, status, createdAt], name: "Order_driver_status_created_idx")
  @@index([paymentStatus, status, createdAt], name: "Order_payment_business_status_created_idx")
}

model OrderCargo {
  orderId         String @id
  cargoType       String
  weightText      String
  volumeText      String?
  quantityText    String
  description     String?
  cargoPhotoCount Int    @default(0)
  cargoPhotoFileIds Json @default("[]")
  order           Order  @relation(fields: [orderId], references: [id])
}

model OrderLocation {
  id            String                     @id @default(uuid())
  orderId       String
  type          String
  address       String
  contactName   String
  contactPhone  String
  noteText      String?
  latitude      Decimal?                   @db.Decimal(10, 7)
  longitude     Decimal?                   @db.Decimal(10, 7)
  geocodeStatus OrderLocationGeocodeStatus @default(none)
  geocodedAt    DateTime?
  order         Order                      @relation(fields: [orderId], references: [id])

  @@index([orderId, type], name: "OrderLocation_order_type_idx")
}

model DriverLocationSnapshot {
  driverId       String               @id
  orderId        String?
  latitude       Decimal              @db.Decimal(10, 7)
  longitude      Decimal              @db.Decimal(10, 7)
  accuracyMeters Float?
  source         DriverLocationSource @default(device)
  recordedAt     DateTime
  updatedAt      DateTime             @updatedAt
  driver         User                 @relation("DriverLocationSnapshot", fields: [driverId], references: [id])
  order          Order?               @relation(fields: [orderId], references: [id])

  @@index([orderId, recordedAt], name: "DriverLocationSnapshot_order_recorded_idx")
  @@index([recordedAt], name: "DriverLocationSnapshot_recorded_idx")
}

model OrderRequirement {
  orderId                String  @id
  vehicleType            String
  vehicleLengthText      String?
  needTailboard          Boolean @default(false)
  needTarp               Boolean @default(false)
  valueAddedServicesText String?
  order                  Order   @relation(fields: [orderId], references: [id])
}

model OrderEvent {
  id                String   @id @default(uuid())
  orderId           String
  actorUserId       String
  eventType         String
  noteText          String?
  attachmentFileIds Json     @default("[]")
  createdAt         DateTime @default(now())
  order             Order    @relation(fields: [orderId], references: [id])
  exceptionCase     OrderExceptionCase? @relation("ExceptionCaseSourceEvent")

  @@index([orderId, createdAt], name: "OrderEvent_order_created_idx")
}

model OrderIdempotencyRecord {
  id                 String   @id @default(uuid())
  actorUserId        String
  orderId            String
  operation          String
  idempotencyKey     String
  requestFingerprint String
  responseSnapshot   Json
  createdAt          DateTime @default(now())
  expiresAt          DateTime
  actor              User     @relation("OrderIdempotencyActor", fields: [actorUserId], references: [id])
  order              Order    @relation(fields: [orderId], references: [id])

  @@unique([actorUserId, operation, idempotencyKey], name: "OrderIdempotencyRecord_actor_operation_key_unique")
  @@index([orderId, createdAt], name: "OrderIdempotencyRecord_order_created_idx")
  @@index([expiresAt], name: "OrderIdempotencyRecord_expires_idx")
}

model OrderExceptionCase {
  id                String                       @id @default(uuid())
  caseNo            String                       @unique
  orderId           String
  sourceEventId     String                       @unique
  reporterUserId    String
  sourceRole        OrderExceptionCaseSourceRole
  typeLabel         String
  description       String
  attachmentFileIds Json                         @default("[]")
  status            OrderExceptionCaseStatus     @default(pending)
  resolutionText    String?
  compensationStatus OrderExceptionCaseCompensationStatus?
  compensationTargetRole OrderExceptionCaseSourceRole?
  compensationAmountCents Int?
  compensationUpdatedAt DateTime?
  compensationTransactionId String?                    @unique
  compensationExecutedAt DateTime?
  appealStatus      OrderExceptionCaseAppealStatus @default(none)
  appealReason      String?
  appealRequestedAt DateTime?
  resolvedAt        DateTime?
  closedAt          DateTime?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  order             Order                        @relation(fields: [orderId], references: [id])
  sourceEvent       OrderEvent                   @relation("ExceptionCaseSourceEvent", fields: [sourceEventId], references: [id])
  reporter          User                         @relation("ExceptionCaseReporter", fields: [reporterUserId], references: [id])
  compensationTransaction FinancialTransaction?    @relation("ExceptionCaseCompensationTransaction", fields: [compensationTransactionId], references: [id])
  actions           OrderExceptionCaseAction[]

  @@index([status, createdAt], name: "OrderExceptionCase_status_created_idx")
  @@index([orderId, createdAt], name: "OrderExceptionCase_order_created_idx")
  @@index([reporterUserId, createdAt], name: "OrderExceptionCase_reporter_created_idx")
}

model OrderExceptionCaseAction {
  id            String                   @id @default(uuid())
  caseId        String
  adminUserId   String
  fromStatus    OrderExceptionCaseStatus
  toStatus      OrderExceptionCaseStatus
  content       String
  createdAt     DateTime                 @default(now())
  exceptionCase OrderExceptionCase       @relation(fields: [caseId], references: [id])
  admin         User                     @relation("ExceptionCaseAdminActions", fields: [adminUserId], references: [id])

  @@index([caseId, createdAt], name: "OrderExceptionCaseAction_case_created_idx")
  @@index([adminUserId, createdAt], name: "OrderExceptionCaseAction_admin_created_idx")
}

model OrderDraft {
  shipperId       String   @id
  draftSnapshot   Json
  clientUpdatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  shipper         User     @relation(fields: [shipperId], references: [id])
}

model ShipperAddressBook {
  shipperId       String   @id
  addresses       Json
  contacts        Json
  clientUpdatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  shipper         User     @relation(fields: [shipperId], references: [id])
}

model ShipperFrequentRoutes {
  shipperId       String   @id
  routes          Json
  clientUpdatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  shipper         User     @relation(fields: [shipperId], references: [id])
}

model ShipperSupportTicket {
  id            String              @id @default(uuid())
  shipperId     String
  channelName   String
  description   String
  status        SupportTicketStatus @default(pending)
  statusHistory Json                @default("[]")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  shipper       User                @relation(fields: [shipperId], references: [id])

  @@index([shipperId, createdAt], name: "ShipperSupportTicket_shipper_created_idx")
  @@index([shipperId, status, createdAt], name: "ShipperSupportTicket_shipper_status_created_idx")
}

model ShipperCoupon {
  id                  String   @id @default(uuid())
  shipperId           String
  title               String
  status              String   @default("usable")
  conditionText       String
  discountCents       Int
  minOrderAmountCents Int
  validFrom           DateTime
  validUntil          DateTime
  sourceText          String
  issuedAt            DateTime @default(now())
  lockedOrderNo       String?
  lockedAt            DateTime?
  usedOrderNo         String?
  usedAt              DateTime?
  shipper             User     @relation(fields: [shipperId], references: [id])

  @@index([shipperId, status, issuedAt], name: "ShipperCoupon_shipper_status_issued_idx")
  @@index([shipperId, validUntil], name: "ShipperCoupon_shipper_valid_until_idx")
}

model ShipperIdentityVerification {
  shipperId           String              @id
  realName            String
  idNumber            String
  identityFrontFileId String
  identityBackFileId  String
  faceVerified        Boolean             @default(true)
  status              CertificationStatus @default(reviewing)
  rejectionReason     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  shipper             User                @relation(fields: [shipperId], references: [id])
}

model ShipperEnterpriseVerification {
  shipperId        String              @id
  enterpriseName   String
  creditCode       String
  legalName        String
  legalId          String
  enterprisePhone  String
  licenseFileId    String
  status           CertificationStatus @default(reviewing)
  rejectionReason  String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  shipper          User                @relation(fields: [shipperId], references: [id])
}

model ShipperInvoiceApplication {
  id               String              @id @default(uuid())
  shipperId        String
  invoiceType      String
  invoiceTitleType String
  invoiceTitle     String
  receiverEmail    String
  orderIds         Json
  orderNos         Json
  amountCents      Int
  status           CertificationStatus @default(reviewing)
  rejectionReason  String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  shipper          User                @relation(fields: [shipperId], references: [id])

  @@index([shipperId, createdAt], name: "ShipperInvoiceApplication_shipper_created_idx")
}

model DriverIdentityCertification {
  driverId            String              @id
  realName            String
  identityNumber      String
  identityFrontFileId String
  identityBackFileId  String
  status              CertificationStatus @default(reviewing)
  rejectionReason     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  driver              User                @relation("DriverIdentityCertification", fields: [driverId], references: [id])
}

model DriverVehicleCertification {
  driverId             String              @id
  plateNumber          String
  vehicleType          String
  vehicleLengthText    String
  loadCapacityText     String
  hasTailboard         Boolean             @default(false)
  drivingLicenseFileId String
  driverLicenseFileId  String?
  transportQualificationFileId String?
  operationPermitFileId String?
  vehiclePhotoFileId   String
  status               CertificationStatus @default(reviewing)
  rejectionReason      String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  driver               User                @relation("DriverVehicleCertification", fields: [driverId], references: [id])
}

model DriverAcceptanceSettings {
  driverId                String   @id
  isOnline                Boolean  @default(true)
  maxDistanceKm           Int      @default(50)
  vehicleTypePreferences  Json     @default("[]")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  driver                  User     @relation(fields: [driverId], references: [id])
}

enum DriverWithdrawalStatus {
  reviewing
  paid
  rejected
}

model DriverWithdrawal {
  id                     String                 @id @default(uuid())
  driverId               String
  amountCents            Int
  bankAccountName        String
  bankName               String
  bankAccountMasked      String
  status                 DriverWithdrawalStatus @default(reviewing)
  idempotencyKey         String?
  requestFingerprint     String?
  version                Int                    @default(0)
  rejectionReason        String?
  processedByAdminId     String?
  processedAt            DateTime?
  payoutChannel          String?
  providerPayoutNo       String?
  payoutExecutedAt       DateTime?
  financialTransactionId String?                @unique
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  driver                 User                   @relation("DriverWithdrawals", fields: [driverId], references: [id])
  processedByAdmin       User?                  @relation("DriverWithdrawalProcessor", fields: [processedByAdminId], references: [id])
  financialTransaction   FinancialTransaction?  @relation(fields: [financialTransactionId], references: [id])

  @@index([driverId, createdAt], name: "DriverWithdrawal_driver_created_idx")
  @@unique([driverId, idempotencyKey], name: "DriverWithdrawal_driver_idempotency_key_unique")
  @@index([status, createdAt], name: "DriverWithdrawal_status_created_idx")
  @@index([providerPayoutNo], name: "DriverWithdrawal_provider_payout_no_idx")
}

model DriverBankCard {
  id              String   @id @default(uuid())
  driverId        String
  bankAccountName String
  bankName        String
  bankAccountNo   String
  isDefault       Boolean  @default(false)
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  driver          User     @relation("DriverBankCards", fields: [driverId], references: [id])

  @@index([driverId, createdAt], name: "DriverBankCard_driver_created_idx")
  @@unique([driverId, bankAccountNo], name: "DriverBankCard_driver_account_unique")
}

model PaymentOrder {
  id                    String             @id @default(uuid())
  paymentNo             String             @unique
  orderId               String
  shipperId             String
  channel               PaymentChannel
  amountCents           Int
  status                PaymentOrderStatus @default(pending)
  idempotencyKey        String
  requestFingerprint    String
  clientPayload         Json?
  providerTradeNo       String?
  failureCode           String?
  failureMessage        String?
  expiresAt             DateTime
  paidAt                DateTime?
  settledAt             DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  order                 Order              @relation(fields: [orderId], references: [id])
  shipper               User               @relation(fields: [shipperId], references: [id])
  callbackEvents        PaymentCallbackEvent[]
  refund                Refund?
  settlement            Settlement?
  financialTransactions FinancialTransaction[]

  @@unique([shipperId, idempotencyKey], name: "PaymentOrder_shipper_idempotency_key_unique")
  @@unique([channel, providerTradeNo], name: "PaymentOrder_channel_provider_trade_no_unique")
  @@index([orderId, createdAt], name: "PaymentOrder_order_created_idx")
  @@index([shipperId, status, createdAt], name: "PaymentOrder_shipper_status_created_idx")
}

model PaymentCallbackEvent {
  id               String         @id @default(uuid())
  channel          PaymentChannel
  eventId          String
  eventType        String
  paymentOrderId   String?
  refundId         String?
  rawPayloadHash   String
  processingResult String
  occurredAt       DateTime
  processedAt      DateTime       @default(now())
  createdAt        DateTime       @default(now())
  paymentOrder     PaymentOrder?  @relation(fields: [paymentOrderId], references: [id])
  refund           Refund?        @relation(fields: [refundId], references: [id])

  @@unique([channel, eventId], name: "PaymentCallbackEvent_channel_event_unique")
  @@index([paymentOrderId, createdAt], name: "PaymentCallbackEvent_payment_created_idx")
  @@index([refundId, createdAt], name: "PaymentCallbackEvent_refund_created_idx")
}

model Refund {
  id                     String               @id @default(uuid())
  refundNo               String               @unique
  paymentOrderId         String               @unique
  orderId                String
  shipperId              String
  channel                PaymentChannel
  amountCents            Int
  reason                 String
  status                 RefundStatus         @default(pending)
  providerRefundNo       String?
  failureCode            String?
  failureMessage         String?
  processingStartedAt    DateTime?
  succeededAt            DateTime?
  failedAt               DateTime?
  financialTransactionId String?              @unique
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  paymentOrder           PaymentOrder         @relation(fields: [paymentOrderId], references: [id])
  order                  Order                @relation(fields: [orderId], references: [id])
  shipper                User                 @relation(fields: [shipperId], references: [id])
  callbackEvents         PaymentCallbackEvent[]
  outboxEvents           FinancialOutboxEvent[]
  financialTransaction   FinancialTransaction? @relation(fields: [financialTransactionId], references: [id])

  @@unique([channel, providerRefundNo], name: "Refund_channel_provider_refund_no_unique")
  @@index([orderId, createdAt], name: "Refund_order_created_idx")
  @@index([shipperId, status, createdAt], name: "Refund_shipper_status_created_idx")
}

model Settlement {
  id                     String               @id @default(uuid())
  orderId                String               @unique
  paymentOrderId         String?              @unique
  driverId               String
  grossAmountCents       Int
  platformFeeRateBps     Int
  platformFeeCents       Int
  driverNetAmountCents   Int
  financialTransactionId String               @unique
  settledAt              DateTime             @default(now())
  createdAt              DateTime             @default(now())
  order                  Order                @relation(fields: [orderId], references: [id])
  paymentOrder           PaymentOrder?        @relation(fields: [paymentOrderId], references: [id])
  driver                 User                 @relation(fields: [driverId], references: [id])
  financialTransaction   FinancialTransaction @relation(fields: [financialTransactionId], references: [id])

  @@index([driverId, settledAt], name: "Settlement_driver_settled_idx")
}

model FinancialTransaction {
  id                 String                   @id @default(uuid())
  transactionNo      String                   @unique
  type               FinancialTransactionType
  referenceId        String
  orderId            String?
  paymentOrderId     String?
  amountCents        Int
  occurredAt         DateTime
  createdAt          DateTime                 @default(now())
  order              Order?                   @relation(fields: [orderId], references: [id])
  paymentOrder       PaymentOrder?            @relation(fields: [paymentOrderId], references: [id])
  entries            FinancialLedgerEntry[]
  refund             Refund?
  settlement         Settlement?
  driverWithdrawal   DriverWithdrawal?
  exceptionCase      OrderExceptionCase?      @relation("ExceptionCaseCompensationTransaction")

  @@unique([type, referenceId], name: "FinancialTransaction_type_reference_unique")
  @@index([orderId, occurredAt], name: "FinancialTransaction_order_occurred_idx")
  @@index([paymentOrderId, occurredAt], name: "FinancialTransaction_payment_occurred_idx")
  @@index([type, occurredAt], name: "FinancialTransaction_type_occurred_idx")
}

model FinancialLedgerEntry {
  id            String               @id @default(uuid())
  transactionId String
  sequence      Int
  accountType   FinancialAccountType
  accountUserId String?
  direction     LedgerDirection
  amountCents   Int
  createdAt     DateTime             @default(now())
  transaction   FinancialTransaction @relation(fields: [transactionId], references: [id])
  accountUser   User?                @relation(fields: [accountUserId], references: [id])

  @@unique([transactionId, sequence], name: "FinancialLedgerEntry_transaction_sequence_unique")
  @@index([accountType, accountUserId, createdAt], name: "FinancialLedgerEntry_account_created_idx")
}

model DriverWallet {
  driverId       String   @id
  availableCents Int      @default(0)
  reservedCents  Int      @default(0)
  withdrawnCents Int      @default(0)
  version        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  driver         User     @relation(fields: [driverId], references: [id])
}

model FinancialOutboxEvent {
  id             String                @id @default(uuid())
  eventType      String
  aggregateType  String
  aggregateId    String
  refundId       String?
  payload        Json
  status         FinancialOutboxStatus @default(pending)
  attemptCount   Int                   @default(0)
  maxAttempts    Int                   @default(10)
  availableAt    DateTime              @default(now())
  claimedAt      DateTime?
  leaseExpiresAt DateTime?
  claimedBy      String?
  processedAt    DateTime?
  lastError      String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  refund         Refund?               @relation(fields: [refundId], references: [id])

  @@unique([eventType, aggregateType, aggregateId], name: "FinancialOutboxEvent_aggregate_event_unique")
  @@index([status, availableAt, createdAt], name: "FinancialOutboxEvent_claim_idx")
  @@index([leaseExpiresAt], name: "FinancialOutboxEvent_lease_expires_idx")
}

model FinancialAuditLog {
  id                 String   @id @default(uuid())
  actorAdminId       String
  action             String
  entityType         String
  entityId           String
  idempotencyKey     String
  requestFingerprint String
  requestId          String
  reason             String
  beforeState        Json?
  afterState         Json?
  createdAt          DateTime @default(now())
  actorAdmin         User     @relation(fields: [actorAdminId], references: [id])

  @@unique([actorAdminId, action, idempotencyKey], name: "FinancialAuditLog_actor_action_key_unique")
  @@index([entityType, entityId, createdAt], name: "FinancialAuditLog_entity_created_idx")
  @@index([actorAdminId, createdAt], name: "FinancialAuditLog_actor_created_idx")
}

model AdminAuthSessionGovernanceAuditEvent {
  id                 String                                @id @default(uuid())
  actorAdminId       String
  actorAdminPhone    String
  action             AdminAuthSessionGovernanceAuditAction
  result             AdminAuthSessionGovernanceAuditResult
  requestedSessionId String?
  currentDeviceId    String?
  revokedCount       Int                                   @default(0)
  subjects           Json                                  @default("[]")
  createdAt          DateTime                              @default(now())
  actorAdmin         User                                  @relation("AdminAuthSessionGovernanceAuditActorEvents", fields: [actorAdminId], references: [id])

  @@index([actorAdminId, createdAt], name: "AdminAuthSessionGovernanceAuditEvent_actor_created_idx")
  @@index([action, createdAt], name: "AdminAuthSessionGovernanceAuditEvent_action_created_idx")
}

model DriverCertificationReviewEvent {
  id                String                  @id @default(uuid())
  driverId          String
  reviewerAdminId   String
  certificationType DriverCertificationType
  fromStatus        CertificationStatus
  toStatus          CertificationStatus
  rejectionReason   String?
  createdAt         DateTime                @default(now())
  driver            User                    @relation("DriverCertificationReviewEvents", fields: [driverId], references: [id])
  reviewerAdmin     User                    @relation("DriverCertificationReviewerEvents", fields: [reviewerAdminId], references: [id])

  @@index([driverId, createdAt], name: "DriverCertificationReviewEvent_driver_created_idx")
  @@index([reviewerAdminId, createdAt], name: "DriverCertificationReviewEvent_reviewer_created_idx")
}


model InboxMessage {
  id            String               @id @default(uuid())
  userId        String
  audience      InboxMessageAudience
  category      InboxMessageCategory
  title         String
  content       String
  orderId       String?
  orderNo       String?
  referenceType String?
  referenceId   String?
  unread        Boolean              @default(true)
  readAt        DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  user          User                 @relation("InboxMessageRecipient", fields: [userId], references: [id])
  pushAttempts  PushDeliveryAttempt[]

  @@index([userId, unread, createdAt], name: "InboxMessage_user_unread_created_idx")
  @@index([userId, createdAt], name: "InboxMessage_user_created_idx")
  @@index([orderId, createdAt], name: "InboxMessage_order_created_idx")
  @@index([referenceType, referenceId], name: "InboxMessage_reference_idx")
}

model PushDeliveryAttempt {
  id                String             @id @default(uuid())
  messageId         String
  channel           String
  status            PushDeliveryStatus
  providerMessageId String?
  errorMessage      String?
  createdAt         DateTime           @default(now())
  message           InboxMessage       @relation(fields: [messageId], references: [id])

  @@index([messageId, createdAt], name: "PushDeliveryAttempt_message_created_idx")
  @@index([status, createdAt], name: "PushDeliveryAttempt_status_created_idx")
}
