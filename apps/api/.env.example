NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://truck:truck@localhost:5432/truck_platform
TEST_DATABASE_URL=postgresql://truck:truck@localhost:5432/truck_platform_test
JWT_ACCESS_SECRET=replace-with-dev-access-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
VERIFICATION_CODE_TTL_SECONDS=300
# Successful order mutations can be replayed with the same idempotency key
# during this window. Expired keys remain reserved and cannot be rebound.
ORDER_IDEMPOTENCY_TTL_SECONDS=86400
# Payment is disabled until a sandbox or live provider is configured.
PAYMENT_PROVIDER_MODE=disabled
PAYMENT_PLATFORM_FEE_BPS=500
PAYMENT_ORDER_TTL_SECONDS=900
# PAYMENT_PROVIDER_MODE=sandbox
# PAYMENT_SANDBOX_SECRET=replace-with-at-least-32-characters
# PAYMENT_CALLBACK_BASE_URL=https://api.example.com/api
# PAYMENT_PROVIDER_MODE=wechat
# WECHAT_PAY_APP_ID=wx-app-id
# WECHAT_PAY_MCH_ID=merchant-id
# WECHAT_PAY_MERCHANT_SERIAL_NO=merchant-certificate-serial
# WECHAT_PAY_MERCHANT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# WECHAT_PAY_PLATFORM_SERIAL_NO=platform-certificate-serial
# WECHAT_PAY_PLATFORM_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# WECHAT_PAY_API_V3_KEY=replace-with-exactly-32-bytes
# PAYMENT_PROVIDER_MODE=alipay
# ALIPAY_APP_ID=alipay-app-id
# ALIPAY_SELLER_ID=alipay-seller-id
# ALIPAY_MERCHANT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# ALIPAY_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Local upload and public file URL generation.
# FILE_UPLOAD_URL_BASE=http://localhost:3000/api/files/uploads
# FILE_PUBLIC_URL_BASE=https://files.example.com/public
# Local provider storage root for bytes received by POST /files/uploads/:fileId.
# FILE_STORAGE_ROOT=local-file-storage
# Maps provider. First slice only supports sandbox deterministic geocode.
# MAP_PROVIDER=sandbox
# S3-compatible object storage upload signing. Supports MinIO/AWS S3 compatible APIs.
# FILE_STORAGE_PROVIDER=local
# FILE_STORAGE_PROVIDER=s3-compatible
# S3_ENDPOINT=https://s3.example.com
# S3_REGION=cn-north-1
# S3_BUCKET=truck-files
# S3_ACCESS_KEY_ID=replace-with-access-key
# S3_SECRET_ACCESS_KEY=replace-with-secret-key
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_URL_BASE=https://files.example.com/public
# S3_UPLOAD_EXPIRES_IN_SECONDS=900
# FILE_STORAGE_CALLBACK_SIGNING_SECRET=replace-with-at-least-32-characters
# Optional interval for backend metadata cleanup of expired pending file objects.
# Disabled by default; set a positive number of seconds to run it in-process.
# FILE_PENDING_CLEANUP_INTERVAL_SECONDS=3600
# Production SMS delivery can use the generic webhook sender.
# SMS_PROVIDER=webhook
# SMS_WEBHOOK_URL=https://sms.example.com/send
# SMS_WEBHOOK_TOKEN=replace-with-production-webhook-token
# SMS_WEBHOOK_TIMEOUT_MS=5000

# Short-lived local/admin certification attachment preview URLs.
# Production must provide a strong signing secret; real S3/OSS preview signing is a later integration.
# FILE_PREVIEW_URL_BASE=https://files.example.com/preview-contents
# FILE_PREVIEW_EXPIRES_IN_SECONDS=600
# FILE_PREVIEW_SIGNING_SECRET=replace-with-production-file-preview-secret
